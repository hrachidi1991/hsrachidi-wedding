generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id        String   @id @default("main")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model TimelineItem {
  id        String   @id @default(uuid())
  time      String
  labelEn   String
  labelAr   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guest {
  id          String   @id @default(uuid())
  name        String
  phone       String?
  side        String   @default("groom") // "bride" | "groom"
  relation    String   @default("friend")
  groupCode   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  seat        Seat?

  @@index([groupCode])
  @@index([side])
}

// Seating map — assignment of a Guest to a physical chair. The chair geometry
// (positions traced from the venue floor plan) lives in code (lib/seatLayout);
// the DB stores only which Guest sits in which seat `code`. Real FK to Guest.
model Seat {
  id        String   @id @default(uuid())
  code      String   @unique          // matches a chair code from lib/seatLayout, e.g. "A1-05"
  guestId   String?  @unique          // one guest per seat
  guest     Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GuestGroup {
  id          String       @id @default(uuid())
  groupCode   String       @unique
  maxGuests   Int          @default(2)
  token       String       @unique @default(uuid())
  side        String       @default("groom")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rsvpResponse RsvpResponse?

  @@index([token])
}

model RsvpResponse {
  id              String   @id @default(uuid())
  groupId         String   @unique
  group           GuestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attending       Boolean
  numberAttending Int      @default(0)
  guestNames      Json     @default("[]") // string[]
  language        String   @default("en")
  submittedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([groupId])
}
