generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SiteSettings {
  id        String   @id @default("main")
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt
}

model TimelineItem {
  id        String   @id @default(uuid())
  time      String
  labelEn   String
  labelAr   String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Guest {
  id          String   @id @default(uuid())
  name        String
  displayName String?  // name shown on the invitation link (defaults to `name`)
  phone       String?
  side        String   @default("groom") // "bride" | "groom"
  relation    String   @default("friend")
  circle      String?  // guest "circle": Immediate Fam | Fathers | Mothers | Ghassan Guests | Ranas Guests | Friends | Social
  rsvpManual  String?  // manual RSVP override: "" | "Pending" | "Coming" | "Not coming" (overrides the online RSVP)
  notes       String?  // free-text admin notes
  waSentCount Int      @default(0) // how many times the WhatsApp invite link was sent to this guest
  waSentAt    DateTime? // when the invite link was last sent on WhatsApp
  groupCode   String
  sortOrder   Int      @default(0) // preserves display order within a group
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  seat        Seat?

  @@index([groupCode])
  @@index([side])
}

// Seating map — assignment of a Guest to a physical chair. The chair geometry
// (positions traced from the venue floor plan) lives in code (lib/seatLayout);
// the DB stores only which Guest sits in which seat `code`. Real FK to Guest.
model Seat {
  id        String   @id @default(uuid())
  code      String   @unique          // matches a chair code from lib/seatLayout, e.g. "A1-05"
  guestId   String?  @unique          // one guest per seat
  guest     Guest?   @relation(fields: [guestId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GuestGroup {
  id          String       @id @default(uuid())
  groupCode   String       @unique
  maxGuests   Int          @default(2)
  token       String       @unique @default(uuid())
  side        String       @default("groom")
  inRsvp      Boolean      @default(false) // in RSVP tracking (invite link sent, or added manually)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rsvpResponse RsvpResponse?

  @@index([token])
}

model RsvpResponse {
  id              String   @id @default(uuid())
  groupId         String   @unique
  group           GuestGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  attending       Boolean
  numberAttending Int      @default(0)
  guestNames      Json     @default("[]") // string[]
  language        String   @default("en")
  submittedAt     DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([groupId])
}

// Two-way chat between a guest (via their private invite link) and the couple
// (via the admin RSVP panel). Scoped to a group by groupCode — only that link
// sees its own thread. `sender` is "guest" or "couple".
model GuestMessage {
  id        String   @id @default(uuid())
  groupCode String
  sender    String   @default("guest") // "guest" | "couple"
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupCode])
}
